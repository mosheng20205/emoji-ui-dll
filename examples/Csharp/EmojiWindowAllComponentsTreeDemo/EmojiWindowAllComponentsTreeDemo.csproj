<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <LangVersion>latest</LangVersion>
    <Prefer32Bit>false</Prefer32Bit>
    <RootNamespace>EmojiWindowDemo</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\DemoCommon\EmojiWindowNative.cs" Link="DemoCommon\EmojiWindowNative.cs" />
    <Compile Include="..\DemoCommon\DemoRuntime.cs" Link="DemoCommon\DemoRuntime.cs" />
    <Compile Include="..\DemoCommon\DemoScenarios.cs" Link="DemoCommon\DemoScenarios.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\..\x64\Release\emoji_window.dll" Condition="Exists('..\..\..\x64\Release\emoji_window.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
